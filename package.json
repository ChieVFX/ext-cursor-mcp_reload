{
  "name": "reload",
  "displayName": "Cursor MCP Reload",
  "description": "Auto-registers a Cursor MCP tool that reloads Cursor MCP servers; also updates on file '.cursor/reload-mcps.json'.",
  "version": "0.5.11",
  "publisher": "chievfx",
  "author": "Evgeniy Skvortsov",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/evgeniy-skvortsov/cursor-reload-mcps.git"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "contributes": {
    "configuration": {
      "title": "Cursor MCP Reload",
      "properties": {
        "reload.reloadViaFile": {
          "type": "boolean",
          "default": true,
          "description": "Watch .cursor/reload-mcps.json in the workspace and reload MCPs when it appears."
        },
        "reload.debugReloadViaFile": {
          "type": "boolean",
          "default": false,
          "description": "Debug: write .cursor/reload-mcps.result.json with success or failure for file reload requests."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs --production",
    "watch": "node esbuild.config.mjs --watch",
    "package": "vsce package",
    "install:cursor": "node scripts/install-cursor.mjs --force",
    "reinstall": "npm run package && npm run install:cursor"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
